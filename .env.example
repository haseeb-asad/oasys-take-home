# Copy to `.env` and fill in. NEVER commit the real `.env`.

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg://kinetic:kinetic@localhost:5432/kinetic
TEST_DATABASE_URL=postgresql+psycopg://kinetic:kinetic@localhost:5432/kinetic_test

# JWT — placeholder only; generate a real secret for any non-local use
JWT_SECRET_KEY=change-me-for-local-dev
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
